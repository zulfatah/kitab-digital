# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# JWT Secret for signing custom auth tokens
JWT_SECRET="super_secret_jwt_key_12345"

# MySQL Database configuration variables (if user decides to connect a real MySQL instance)
DB_HOST="localhost"
DB_USER="root"
DB_PASSWORD="rootpassword"
DB_NAME="kitab_collab_db"
DB_PORT="3306"

# Firebase Client configuration (Vite exposed variables)
VITE_FIREBASE_API_KEY="AIzaSyCrIMDQ..."
VITE_FIREBASE_PROJECT_ID="your-project-id"
VITE_FIREBASE_APP_ID="1:xxxx:web:xxxx"
VITE_FIREBASE_AUTH_DOMAIN="your-project-id.firebaseapp.com"
VITE_FIREBASE_FIRESTORE_DATABASE_ID="(default) or custom database-id"
VITE_FIREBASE_STORAGE_BUCKET="your-project-id.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID="xxxxxxxx"

